{
  "version": "0.2.0",
  // The C++ mods (TPVCamera, TPVToggle) build as injected .asi DLLs with no
  // standalone executable, so debugging means attaching the MSVC debugger to the
  // running game once the mod has loaded. Build a dev preset first (msvc-dev is
  // RelWithDebInfo and emits PDBs) so the symbols match the loaded binary.
  "configurations": [
    {
      "name": "Attach to game (MSVC)",
      "type": "cppvsdbg",
      "request": "attach",
      "processId": "${command:pickProcess}"
    }
  ]
}
